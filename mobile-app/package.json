{
  "name": "sync-camera-mobile",
  "version": "1.0.0",
  "description": "Mobile camera app for sync-camera 2-camera Padel court coverage system",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
